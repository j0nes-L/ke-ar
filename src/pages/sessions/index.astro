---
import BaseLayout from "../../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="[KE-AR] - Sessions">
  <section id="login-view" class="login-view hidden">
    <div class="login-card">
      <h2 class="login-title">Session Access</h2>
      <p class="login-desc">Enter the password to access recorded sessions.</p>
      <div class="login-form">
        <input
          type="password"
          id="pw-input"
          placeholder="Password"
          autocomplete="off"
          aria-label="Session access password"
          class="login-input"
        />
        <button id="pw-submit" class="btn btn-primary">Unlock</button>
      </div>
      <p id="pw-error" class="login-error hidden">Invalid password. Please try again.</p>
    </div>
  </section>

  <section id="dashboard-view" class="dashboard hidden">
    <div id="list-view">
      <div class="dash-toolbar">
        <h2 class="section-title">Recorded Sessions</h2>
        <div class="dash-toolbar-actions">
          <button id="btn-refresh" class="btn-icon-action" title="Refresh">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"></polyline>
              <polyline points="1 20 1 14 7 14"></polyline>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            </svg>
          </button>
          <button id="btn-logout" class="btn btn-ghost">Logout</button>
        </div>
      </div>

      <div class="upload-card">
        <p class="upload-hint">Select session files to upload (.json, .bin, .wav, etc.). Upload starts automatically.</p>
        <div class="upload-row">
          <input type="file" id="upload-files" multiple class="upload-input" accept=".json,.bin,.wav" />
        </div>
        <div id="upload-session-id-row" class="upload-session-id-row hidden">
          <label for="upload-session-id" class="upload-session-id-label">
            No Session ID found in filenames – please enter the Session ID:
          </label>
          <div class="upload-session-id-input-row">
            <input type="text" id="upload-session-id" placeholder="e.g. a1b2c3d4-e5f6-7890-abcd-ef1234567890" class="upload-session-id-input" />
            <button id="upload-session-id-confirm" class="btn btn-primary btn-sm">Upload</button>
          </div>
        </div>
        <div id="upload-file-list" class="upload-file-list hidden"></div>
        <p id="upload-status" class="upload-status hidden"></p>
      </div>

      <div id="sessions-list-wrap" class="sessions-list-wrap">
        <div id="sessions-loading" class="status-msg">
          <span class="spinner"></span> Loading sessions…
        </div>
        <p id="sessions-empty" class="status-msg hidden">No sessions found.</p>
        <div id="sessions-list" class="sessions-list hidden"></div>
        <div id="pagination" class="pagination hidden">
          <button id="pg-prev" class="btn btn-secondary btn-sm" disabled>← Prev</button>
          <span id="pg-info" class="pg-info"></span>
          <button id="pg-next" class="btn btn-secondary btn-sm">Next →</button>
        </div>
      </div>
    </div>

    <div id="detail-view" class="hidden">
      <div class="dash-toolbar">
        <div class="detail-nav">
          <a id="btn-back" class="btn btn-secondary btn-sm" href={`${base}sessions/`}>← Sessions</a>
          <h2 id="detail-title" class="detail-title"></h2>
        </div>
        <div class="dash-toolbar-actions">
          <button id="btn-delete-session" class="btn-icon-action btn-icon-delete" title="Delete session">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              <line x1="10" y1="11" x2="10" y2="17"></line>
              <line x1="14" y1="11" x2="14" y2="17"></line>
            </svg>
          </button>
          <button id="btn-logout-detail" class="btn btn-ghost">Logout</button>
        </div>
      </div>

      <div id="detail-meta" class="detail-meta-grid"></div>

      <details id="detail-meta-advanced" class="detail-meta-advanced hidden">
        <summary class="detail-meta-summary">Technical Details</summary>
        <div id="detail-meta-advanced-content" class="detail-meta-advanced-content"></div>
      </details>

      <div id="detail-loading" class="status-msg">
        <span class="spinner"></span> Loading session…
      </div>
      <div id="detail-files" class="detail-files hidden"></div>


      <div id="frame-meta-overlay" class="frame-meta-overlay hidden">
        <div class="frame-meta-dialog">
          <div class="frame-meta-header">
            <h3 id="frame-meta-title" class="frame-meta-title">Frame</h3>
            <button id="frame-meta-close" class="btn-icon-action" title="Close">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
          <div id="frame-meta-content" class="frame-meta-content"></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import "../../scripts/sessions/index";
</script>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .spinner {
    display: inline-block;
    width: 18px;
    height: 18px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    vertical-align: middle;
    margin-right: 0.5rem;
  }

  .spinner-sm {
    width: 14px;
    height: 14px;
    border-width: 1.5px;
  }

  .login-view {
    display: flex;
    justify-content: center;
    padding-top: 4rem;
  }

  .login-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
    animation: fadeIn 0.3s ease;
  }

  .login-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .login-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .login-form {
    display: flex;
    gap: 0.75rem;
  }

  .login-input {
    flex: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-size: 0.95rem;
    padding: 0.7rem 1rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .login-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(109, 93, 252, 0.15);
  }

  .login-error {
    color: var(--color-danger);
    font-size: 0.85rem;
  }

  .dashboard {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    animation: fadeIn 0.3s ease;
  }

  .dash-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .dash-toolbar-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .detail-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .detail-title {
    font-size: 0.95rem;
    font-weight: 600;
    font-family: monospace;
    word-break: break-all;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  :global(.detail-meta-grid) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    margin-top: 0.75rem;
  }

  :global(.meta-item) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  :global(.meta-label) {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  :global(.meta-value) {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .detail-meta-advanced {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-top: 0.75rem;
    overflow: hidden;
  }

  .detail-meta-summary {
    padding: 0.7rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    cursor: pointer;
    user-select: none;
    transition: color var(--transition), background var(--transition);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .detail-meta-summary::before {
    content: "▸";
    transition: transform 0.2s ease;
    font-size: 0.7rem;
  }

  .detail-meta-advanced[open] > .detail-meta-summary::before {
    transform: rotate(90deg);
  }

  .detail-meta-summary:hover {
    color: var(--color-text);
    background: var(--color-surface-hover);
  }

  .detail-meta-summary::-webkit-details-marker {
    display: none;
  }

  .detail-meta-advanced-content {
    padding: 0.5rem 1.25rem 1rem;
    animation: fadeIn 0.2s ease;
  }

  :global(.adv-section-title) {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin: 0.75rem 0 0.35rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.adv-section-title:first-child) {
    margin-top: 0;
  }

  :global(.adv-table) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  :global(.adv-row) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.2rem 0;
    font-size: 0.78rem;
    border-bottom: 1px solid rgba(42, 42, 46, 0.4);
  }

  :global(.adv-row:last-child) {
    border-bottom: none;
  }

  :global(.adv-key) {
    color: var(--color-text-muted);
    font-weight: 500;
    flex-shrink: 0;
    white-space: nowrap;
  }

  :global(.adv-val) {
    color: var(--color-text);
    text-align: right;
    word-break: break-all;
    min-width: 0;
  }

  :global(.adv-bool-true) { color: #22c55e; }
  :global(.adv-bool-false) { color: var(--color-text-muted); }
  :global(.adv-null) { color: var(--color-text-muted); font-style: italic; }
  :global(.adv-nested-key) {
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.72rem;
  }

  .sessions-list-wrap {
    margin-top: 0.5rem;
  }

  .upload-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .upload-hint {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .upload-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .upload-input {
    flex: 1;
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .upload-input::file-selector-button {
    background: var(--color-surface-hover);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    padding: 0.4rem 0.8rem;
    font-family: inherit;
    cursor: pointer;
    margin-right: 0.75rem;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .upload-input::file-selector-button:hover {
    background: var(--color-border);
    border-color: var(--color-text-muted);
  }

  .upload-file-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    animation: fadeIn 0.2s ease;
  }

  :global(.upload-file-item) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    font-size: 0.8rem;
    transition: border-color 0.2s ease;
  }

  :global(.upload-file-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  :global(.upload-file-name) {
    font-weight: 600;
    word-break: break-all;
  }

  :global(.upload-file-meta) {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  :global(.upload-file-bar) {
    font-family: monospace;
    font-size: 0.65rem;
    letter-spacing: 0.5px;
    line-height: 1;
    user-select: none;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  :global(.upload-file-pending) { opacity: 0.5; }
  :global(.upload-file-uploading) { border-color: var(--color-text-muted); }
  :global(.upload-file-uploading .upload-file-bar) { color: var(--color-text); }
  :global(.upload-file-done) { border-color: #22c55e; }
  :global(.upload-file-done .upload-file-bar) { color: #22c55e; }
  :global(.upload-file-done .upload-file-meta) { color: #22c55e; }
  :global(.upload-file-error) { border-color: var(--color-danger); }
  :global(.upload-file-error .upload-file-bar) { color: var(--color-danger); }
  :global(.upload-file-error .upload-file-meta) { color: var(--color-danger); }

  .upload-status { font-size: 0.85rem; font-weight: 600; }
  .upload-status.success { color: #22c55e; }
  .upload-status.error { color: var(--color-danger); }

  .upload-session-id-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: fadeIn 0.2s ease;
  }

  .upload-session-id-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .upload-session-id-input-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .upload-session-id-input {
    flex: 1;
    font-size: 0.85rem;
    font-family: var(--font-mono, monospace);
    padding: 0.45rem 0.7rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .upload-session-id-input:focus {
    border-color: var(--color-text-muted);
  }

  .status-msg {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
    display: flex;
    align-items: center;
  }

  .sessions-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.session-card) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.85rem 1.25rem;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    flex-wrap: wrap;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    animation: fadeIn 0.25s ease both;
  }

  :global(.session-card:hover) {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(109, 93, 252, 0.1);
    transform: translateY(-1px);
  }

  :global(.session-card-info) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    flex: 1;
  }

  :global(.session-id) {
    font-weight: 600;
    font-size: 0.85rem;
    word-break: break-all;
    font-family: monospace;
    letter-spacing: -0.02em;
  }

  :global(.session-meta) {
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }

  :global(.session-card-actions) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  :global(.session-chevron) {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    line-height: 1;
    transition: transform 0.2s ease;
  }

  :global(.session-card:hover .session-chevron) {
    color: var(--color-primary);
    transform: translateX(2px);
  }

  :global(.btn-icon-action) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.1s ease;
  }

  :global(.btn-icon-action:hover) {
    background: var(--color-surface-hover);
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  :global(.btn-icon-action:active) {
    transform: scale(0.93);
  }

  :global(.btn-icon-delete:hover) {
    color: var(--color-danger);
    border-color: var(--color-danger);
    background: rgba(239, 68, 68, 0.08);
  }

  :global(.btn-icon-download:hover) {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(109, 93, 252, 0.08);
  }

  :global(.detail-files) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.75rem;
  }

  :global(.file-row) {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.6rem 1rem;
    flex-wrap: wrap;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  :global(.file-row:hover) {
    border-color: var(--color-text-muted);
    background: var(--color-surface-hover);
  }

  :global(.file-name) {
    font-weight: 600;
    font-size: 0.85rem;
    word-break: break-all;
    flex: 1;
  }

  :global(.file-size) {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding-top: 1rem;
  }

  .pg-info {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  :global(.btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease, color 0.2s ease, transform 0.1s ease,
      box-shadow 0.2s ease, border-color 0.2s ease;
  }

  :global(.btn):active:not(:disabled) {
    transform: scale(0.97);
  }

  :global(.btn-sm) {
    padding: 0.35rem 0.75rem;
    font-size: 0.78rem;
  }

  :global(.btn-primary) {
    background: var(--color-primary);
    color: #fff;
  }

  :global(.btn-primary):hover:not(:disabled) {
    background: var(--color-primary-hover);
    box-shadow: 0 4px 14px rgba(109, 93, 252, 0.25);
  }

  :global(.btn-primary):disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  :global(.btn-secondary) {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  :global(.btn-secondary):hover:not(:disabled) {
    background: var(--color-surface-hover);
    border-color: var(--color-text-muted);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  :global(.btn-secondary):disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  :global(.btn-ghost) {
    background: none;
    color: var(--color-text-muted);
    border: none;
    padding: 0.7rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 600;
  }

  :global(.btn-ghost):hover {
    color: var(--color-text);
    background: var(--color-surface-hover);
  }

  :global(.btn-loading) {
    opacity: 0.7;
    pointer-events: none;
  }

  :global(.btn-download) {
    min-width: 5.5rem;
    text-align: center;
  }

  :global(.hidden) {
    display: none !important;
  }

  @media (max-width: 600px) {
    .dash-toolbar {
      flex-direction: column;
      align-items: stretch;
    }

    .detail-nav {
      flex-direction: column;
      gap: 0.5rem;
    }

    :global(.session-card) {
      flex-direction: column;
      align-items: stretch;
    }

    :global(.session-card-actions) {
      justify-content: flex-end;
    }

    :global(.file-row) {
      flex-direction: column;
      align-items: flex-start;
    }
  }


  :global(.extraction-section) {
    margin-top: 0.75rem;
    padding: 1.25rem;
    background: var(--color-surface);
